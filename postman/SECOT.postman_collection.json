{
  "info": {
    "_postman_id": "c61b6e8f-8f89-4e8a-9a65-f7bf30f2a0a8",
    "name": "SECOT API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth API",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Has access_token', function () {",
                  "  pm.expect(json).to.have.property('access_token');",
                  "});",
                  "",
                  "pm.environment.set('token', json.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Senior API",
      "item": [
        {
          "name": "401 - List Seniors (No Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 401', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/seniors"
          }
        },
        {
          "name": "C - Create Senior",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const ts = Date.now();",
                  "pm.environment.set('senior_codigo', (ts % 1000000) + 1);",
                  "pm.environment.set('senior_email_secot', `autotest_${ts}@secot.local`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Response has id', function () {",
                  "  pm.expect(json).to.have.property('id');",
                  "});",
                  "",
                  "pm.environment.set('senior_id', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senior_codigo\": {{senior_codigo}},\n  \"nombre\": \"Postman\",\n  \"apellido1\": \"Autotest\",\n  \"apellido2\": \"\",\n  \"email_personal\": \"\",\n  \"email_secot\": \"{{senior_email_secot}}\",\n  \"movil\": \"\",\n  \"fecha_alta\": null,\n  \"activo\": true\n}"
            },
            "url": "{{baseUrl}}/api/seniors"
          }
        },
        {
          "name": "R - List Seniors",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Returns array', function () {",
                  "  pm.expect(Array.isArray(json)).to.eql(true);",
                  "});",
                  "",
                  "pm.test('Created senior appears in list', function () {",
                  "  const id = Number(pm.environment.get('senior_id'));",
                  "  pm.expect(json.some((row) => row.id === id)).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/seniors"
          }
        },
        {
          "name": "R - Get Senior By Id",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Returns requested senior', function () {",
                  "  const id = Number(pm.environment.get('senior_id'));",
                  "  pm.expect(json.id).to.eql(id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/seniors/{{senior_id}}"
          }
        },
        {
          "name": "U - Update Senior",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Updates apellido2', function () {",
                  "  pm.expect(json.apellido2).to.eql('Actualizado');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"senior_codigo\": {{senior_codigo}},\n  \"nombre\": \"Postman\",\n  \"apellido1\": \"Autotest\",\n  \"apellido2\": \"Actualizado\",\n  \"email_personal\": null,\n  \"email_secot\": \"{{senior_email_secot}}\",\n  \"movil\": null,\n  \"fecha_alta\": null,\n  \"activo\": true\n}"
            },
            "url": "{{baseUrl}}/api/seniors/{{senior_id}}"
          }
        },
        {
          "name": "D - Delete Senior",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Returns deleted status', function () {",
                  "  pm.expect(json.status).to.eql('deleted');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/seniors/{{senior_id}}"
          }
        }
      ]
    }
  ]
}
